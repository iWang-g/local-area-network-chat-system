# 监听端口（默认 8787）
PORT=8787

# 若设置，请求须带 Header: Authorization: Bearer <与 vs-server 中 LANCS_MAIL_HELPER_SECRET 一致>
MAIL_HELPER_SECRET=

# SMTP 连接串，见 Nodemailer 文档。示例（QQ 邮箱）：smtps://发件邮箱:授权码@smtp.qq.com:465
# 留空时仅打印日志（dry run），便于本机联调不发信
SMTP_URL=

# 发件人显示名与地址
MAIL_FROM="LANCS <noreply@example.com>"

# 邮件主题
MAIL_SUBJECT=您的注册验证码
